{
  "manifest_version": 2,
  "version": "1.1.2",
  "name": "好友申请处理",
  "description": "监听加好友申请，向管理员推送申请人 QQ 资料，并支持通过 /同意 命令一键通过验证并发送欢迎语",
  "author": {
    "name": "白狐",
    "url": "https://github.com/whitefox20011120"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/whitefox20011120/friend-request-handler"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [
    {
      "type": "python_package",
      "name": "aiohttp",
      "version_spec": ">=3.9.0"
    }
  ],
  "capabilities": [
    "send.text",
    "config.get",
    "api.call"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "locales_path": "_locales",
    "supported_locales": [
      "zh-CN"
    ]
  },
  "id": "whitefox.friend-request-handler",
  "display": {
    "icon": {
      "type": "local",
      "value": "assets/icon.svg",
      "fallback": "image",
      "background": "#ffffff"
    }
  }
}
